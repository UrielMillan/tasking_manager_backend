generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum TaskStatus {
  ON_PAUSE
  ON_PROCESS
  COMPLETE
  CANCEL
}

model Task {
  id          Int   @id @default(autoincrement())
  title       String
  description String   
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @map("updated_at")
  subtasks     Subtask[]
  @@map("tasks")
}

model Subtask {
  id          Int   @id @default(autoincrement())
  title       String
  description String   
  status      TaskStatus @default(ON_PAUSE)
  taskId      Int   @map("task_id")
  task        Task  @relation(fields: [taskId], references: [id])

  @@map("sub_tasks")
}